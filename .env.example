SARVAMAI_KEY=YOUR_SARVAM_API_KEY

# Dashboard server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# OCR / PDF processing
TESSERACT_PATH=
OCR_MIN_TEXT_LENGTH=40
OCR_DPI=200
OCR_SEMAPHORE_LIMIT=4
CONTEXT_WINDOW=5
ANALYSIS_CHUNK_SIZE=10

# Sarvam model config
SARVAM_MODEL=sarvam-m
SARVAM_MAX_TOKENS=1200
SARVAM_REASONING_EFFORT=medium

# Embeddings
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=64
EMBEDDING_MAX_CHARS=8000
EMBEDDING_MAX_RETRIES=3

# Animation plugin jobs
ANIMATION_CONTEXT_MAX_CHARS=9000
ANIMATION_RENDER_TIMEOUT_SECONDS=180

# Postgres (pgvector)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=gyandeep
