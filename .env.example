# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# MULTI-LLM PROVIDER (unified configuration)
# Supported: sarvam, openai,  gemini, anthropic, ollama, openrouter


## for ollama
LLM_PROVIDER=ollama
LLM_API_KEY=dummy   # for local ollama this value should be dummy, for other providers you need to get api key from their respective websites
LLM_MODEL=minimax-m2.7:cloud
LLM_MAX_TOKENS=1200
LLM_TEMPERATURE=0.7
LLM_BASE_URL=http://localhost:11434     # only for Ollama , this value should be empty for other providers
LLM_REASONING_EFFORT=medium   # option "low", "medium", or "high" .... only for sarvam model ,  for  other models  whatever value you put it will be ignored


### for other providers  like openai  , gemini , openrouter models or sarvam
LLM_PROVIDER=openai
LLM_API_KEY=your api key    # for local ollama this value should be dummy, for other providers you need to get api key from their respective websites
LLM_MODEL=openaimodel
LLM_MAX_TOKENS=1200
LLM_TEMPERATURE=0.7
LLM_BASE_URL=
LLM_REASONING_EFFORT=medium   # option "low", "medium", or "high" .... only for sarvam model ,  for  other models  whatever value you put it will be ignored




# OCR
TESSERACT_PATH=
OCR_MIN_TEXT_LENGTH=40
OCR_DPI=200
OCR_SEMAPHORE_LIMIT=4

# Context
CONTEXT_WINDOW=5
ANALYSIS_CHUNK_SIZE=10

# Embeddings
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=64

# Animation
ANIMATION_CONTEXT_MAX_CHARS=9000
ANIMATION_RENDER_TIMEOUT_SECONDS=180

# Database
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=gyandeep
